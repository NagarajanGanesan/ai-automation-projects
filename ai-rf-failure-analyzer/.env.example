# Copy to .env and fill in. All values are optional except the API key, which
# is only required for live Claude analysis (the app falls back to a
# deterministic rule-based agent when it is absent).

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=8000
CLAUDE_EFFORT=high
CLAUDE_TIMEOUT_SECONDS=120

# --- Service ---
ENVIRONMENT=development
DEBUG=false

# --- Uploads ---
MAX_UPLOAD_BYTES=52428800

# --- Robot project auto-discovery ---
# Directories scanned (recursively) for output.xml. Relative paths resolve
# against the analyzer package root; absolute paths point at any other repo.
# JSON list when overriding, e.g.:
# PROJECT_ROOTS=["../tests","sample_data"]
# PROJECT_ROOTS=["D:/some-other-repo/results"]
# OUTPUT_GLOB=output*.xml

# --- CORS (comma-free JSON list when overriding) ---
# CORS_ALLOW_ORIGINS=["https://your-frontend.example.com"]
