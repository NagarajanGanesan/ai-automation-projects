# Copy to .env and fill in. All values are optional except the API key, which is
# only required for live Claude generation (the app falls back to a deterministic
# rule-based generator when it is absent).

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=8000
CLAUDE_EFFORT=high
CLAUDE_TIMEOUT_SECONDS=120

# --- Service ---
ENVIRONMENT=development
DEBUG=false

# --- Generation ---
DEFAULT_RECORD_COUNT=3
MAX_RECORD_COUNT=50

# --- CORS (JSON list when overriding) ---
# CORS_ALLOW_ORIGINS=["https://your-frontend.example.com"]
